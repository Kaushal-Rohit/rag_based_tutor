# ── Adaptive RAG Pipeline Configuration ──
# Copy this file to .env and adjust values for your environment.
# All variables are prefixed with RAG_ to avoid collisions.

# ── Paths ──
RAG_DATASET_DIR=./dataset
RAG_FAISS_INDEX_PATH=./data/faiss_hnsw_index.bin
RAG_CHROMA_DB_PATH=./data/chroma_db

# ── Embedding Model ──
RAG_EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ── Ollama LLM ──
RAG_OLLAMA_BASE_URL=http://host.docker.internal:11434
RAG_OLLAMA_MODEL=llama3:latest

# ── Retrieval ──
# Options: chroma | faiss | both
RAG_RETRIEVAL_BACKEND=chroma
RAG_BASE_K=5
RAG_OVERFETCH_FACTOR=10

# ── Sentiment ──
RAG_MAX_HISTORY=5

# ── CRAG (Corrective RAG) ──
RAG_CRAG_ENABLED=true

# ── Logging ──
# Options: DEBUG | INFO | WARNING | ERROR
RAG_LOG_LEVEL=INFO
# Set to true to log full prompt/response text at DEBUG level (privacy/size concern)
RAG_LOG_FULL_CONTENT=false
RAG_LOG_DIR=./logs
